# ─── Engram Taint Watcher ─────────────────────────────────────────────
# Copy this to .env and fill in your values

# Stellar network
HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK=testnet

# Engram API
ENGRAM_API_URL=https://api.engram.sh
ENGRAM_API_KEY=your-api-key-here

# Soroban contract
CONTRACT_ID=CCDAXPPXNXCM25QHYVEWDYBU3FJTNU6Z6BYCHTRRHJEXU6RGVD32PWQF
OPERATOR_SECRET=your-operator-secret-key

# Taint configuration (override contract defaults)
# TAINT_MIN_AMOUNT_XLM=100
# TAINT_MAX_HOPS=2

# Watcher configuration
POLL_INTERVAL_MS=5000
LOG_LEVEL=info
